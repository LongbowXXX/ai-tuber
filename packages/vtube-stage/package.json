{
  "name": "@longbowxxx/vtube-stage",
  "author": "AI Tuber Team",
  "version": "0.0.2",
  "description": "AI Tuber Stage Application",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "build": {
    "appId": "com.aituber.stage",
    "productName": "vtube-stage",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "type": "module",
  "files": [
    "dist-electron",
    "dist",
    "bin",
    "package.json"
  ],
  "main": "dist-electron/main.js",
  "bin": {
    "vtube-stage": "bin/vtube-stage.cjs"
  },
  "scripts": {
    "dev": "vite",
    "prepublishOnly": "npm run build",
    "build": "tsc -b && vite build",
    "build:win": "tsc -b && vite build && electron-builder",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@pixiv/three-vrm": "^3.5.5",
    "@pixiv/three-vrm-animation": "^3.5.5",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "axios": "^1.18.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "electron": "^43.1.1",
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "remark-gfm": "^4.0.1",
    "styled-components": "^6.4.3",
    "three": "^0.185.0",
    "uuid": "^14.0.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.4.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7"
  }
}
